# AI-EDU-CZ — Šablona API klíčů
# -------------------------------------------------------
# ZKOPÍRUJ tento soubor jako .env a doplň své klíče.
# Soubor .env NIKDY nepushuj na GitHub (je v .gitignore).
# Soubor .env.example je bezpečný a jde na GitHub.
# -------------------------------------------------------

# ── Claude / Anthropic ──────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (ChatGPT, DALL-E) ────────────────────────────
OPENAI_API_KEY=sk-...

# ── Google (Gemini, YouTube) ────────────────────────────
GOOGLE_API_KEY=AIza...
GEMINI_API_KEY=AIza...

# ── Grok / xAI ──────────────────────────────────────────
XAI_API_KEY=xai-...

# ── Groq (rychlá inference) ─────────────────────────────
GROQ_API_KEY=gsk_...

# ── Perplexity ──────────────────────────────────────────
PERPLEXITY_API_KEY=pplx-...

# ── Tavily (search pro agenty) ──────────────────────────
TAVILY_API_KEY=tvly-...

# ── ElevenLabs (TTS, hlasy) ─────────────────────────────
ELEVENLABS_API_KEY=...

# ── Pinecone (vektorová databáze) ───────────────────────
PINECONE_API_KEY=...
PINECONE_ENVIRONMENT=...
PINECONE_INDEX_NAME=ai-edu-cz

# ── Supabase (databáze + auth) ──────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ── Resend (emaily) ─────────────────────────────────────
RESEND_API_KEY=re_...

# ── GitHub (pro automatizaci) ───────────────────────────
GITHUB_TOKEN=ghp_...
GITHUB_REPO=haasradek/ai-edu-cz

# ── n8n (self-hosted automatizace) ──────────────────────
N8N_WEBHOOK_URL=http://localhost:5678/webhook/...
N8N_API_KEY=...

# ── Vercel (hosting webu) ───────────────────────────────
VERCEL_TOKEN=...
VERCEL_PROJECT_ID=...

# ── Nastavení projektu ──────────────────────────────────
PROJECT_NAME=AI-EDU-CZ
PROJECT_URL=https://ai-edu-cz.vercel.app
ENVIRONMENT=development
HUGOAI_PATH=C:\Users\haasr\Desktop\hugoai
